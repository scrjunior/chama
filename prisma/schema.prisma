generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model moto {
  id        String   @id @default(cuid())
  nomeMoto  String
  matricula String   @unique
  criadoEm  DateTime @default(now())
  taxistaId String   @unique
  taxista   taxista  @relation(fields: [taxistaId], references: [id])
}

model passageiro {
  id        String   @id @default(cuid())
  nome      String
  apelido   String
  documento String   @unique
  email     String   @unique
  senha     String
  criadoEm  DateTime @default(now())
  viagem    viagem[]
}

model taxista {
  id         String    @id @default(cuid())
  nome       String
  apelido    String
  documento  String    @unique
  email      String    @unique
  senha      String
  criadoEm   DateTime  @default(now())
  disponivel Boolean   @default(false)
  accuracy   Float?
  lastGpsAt  DateTime?
  lat        Float?
  lng        Float?
  moto       moto?
  viagem     viagem[]
}

model viagem {
  id           String        @id @default(cuid())
  status       viagem_status @default(PENDENTE)
  origemTexto  String
  destinoTexto String
  criadoEm     DateTime      @default(now())
  passageiroId String
  taxistaId    String
  passageiro   passageiro    @relation(fields: [passageiroId], references: [id])
  taxista      taxista       @relation(fields: [taxistaId], references: [id])

  @@index([passageiroId])
  @@index([status])
  @@index([taxistaId])
}

enum viagem_status {
  PENDENTE
  ACEITA
  REJEITADA
  CONCLUIDA
  CANCELADA
}
